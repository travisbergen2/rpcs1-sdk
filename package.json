{
  "name": "rpcs1-sdk",
  "version": "0.2.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:web": "npm run build --workspace=packages/core && npm run build --workspace=packages/web",
    "build:all": "node scripts/build-all.mjs",
    "dev": "npm run dev --workspace=packages/web"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  },
  "devDependencies": {
    "@types/three": "^0.179.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20 <27"
  },
  "dependencies": {
    "three": "^0.179.1"
  }
}
