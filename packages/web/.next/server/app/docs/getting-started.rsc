2:T63b,from rpcs1 import recommend_params

config = recommend_params(
    task_description="Customer support agent handling refund requests",
    environment_entropy="dynamic",           # stable | moderate | dynamic | chaotic
    environment_predictability="somewhat_predictable",
    stakes="high",                           # low | medium | high | catastrophic
    context_relevance="medium",              # short | medium | long
    commitment_style="cautious",             # decisive | balanced | cautious
    target_platform="anthropic",             # anthropic | openai | open_source | generic
    domain="customer_support",              # optional — improves confidence rating
)

# Platform parameters
print(config.platform_parameters.temperature)          # 0.52
print(config.platform_parameters.max_tokens)           # 3072
print(config.platform_parameters.model_recommendation) # claude-sonnet-4-6
print(config.platform_parameters.tool_use_strategy)    # cautious_chaining
print(config.platform_parameters.context_strategy)     # rolling_summary

# Receiver profile (the five primitives)
print(config.receiver_profile.TI)  # 30 — short integration (matching principle)
print(config.receiver_profile.SG)  # 35 — low gain (high stakes)
print(config.receiver_profile.FT)  # 75 — high filter (cautious + high stakes)

# Interpretation
print(config.predicted_regime)     # stable
print(config.confidence)           # high
print(config.reasoning)            # cites Matching Principle (Pred-09-5)
for w in config.warnings:
    print(f"⚠ {w}")               # any regime-boundary warnings0:["nHUYCTVjsWTesso99Tkid",[[["",{"children":["docs",{"children":["getting-started",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["docs",{"children":["getting-started",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"children":[["$","h1",null,{"children":"Getting Started"}],["$","h2",null,{"children":"Web tuner (no install)"}],["$","p",null,{"children":["The fastest way to use RPCS-1 is the interactive tuner — no install, no account required. Go to ",["$","a",null,{"href":"/tuner","children":"/tuner"}],", describe your agent, and get recommendations instantly."]}],["$","h2",null,{"children":"Python SDK"}],["$","h3",null,{"children":"Install"}],["$","pre",null,{"children":["$","code",null,{"children":"pip install rpcs1"}]}],["$","p",null,{"children":"With Anthropic integration:"}],["$","pre",null,{"children":["$","code",null,{"children":"pip install rpcs1[anthropic]"}]}],["$","h3",null,{"children":"Basic usage"}],["$","pre",null,{"children":["$","code",null,{"children":"$2"}]}],["$","h3",null,{"children":"Anthropic integration"}],["$","pre",null,{"children":["$","code",null,{"children":"from rpcs1 import recommend_params\nfrom rpcs1.integrations.anthropic import to_anthropic_params\nimport anthropic\n\nrec = recommend_params(\n    task_description=\"Medical triage assistant\",\n    environment_entropy=\"moderate\",\n    environment_predictability=\"somewhat_predictable\",\n    stakes=\"catastrophic\",\n    commitment_style=\"cautious\",\n    target_platform=\"anthropic\",\n)\n\nparams = to_anthropic_params(\n    rec,\n    system_prompt=\"You are a medical intake assistant.\",\n    user_message=\"I have chest pain and shortness of breath.\",\n)\n\nclient = anthropic.Anthropic()\nmessage = client.messages.create(**params)\nprint(message.content[0].text)"}]}],["$","h3",null,{"children":"SDK license key (paid tier)"}],["$","p",null,{"children":"The SDK is open to insta