0:["nHUYCTVjsWTesso99Tkid",[[["",{"children":["docs",{"children":["regimes",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["docs",{"children":["regimes",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"children":[["$","h1",null,{"children":"Stability Regimes"}],["$","p",null,{"children":"The RPCS-1 framework identifies four stability regimes. The tuner predicts which regime your agent will operate in under the recommended parameters and warns when configuration is near a failure boundary."}],["$","h2",null,{"children":"Stable"}],["$","p",null,{"children":"Balanced primitives, well-matched to environment. The agent takes action when appropriate, integrates context appropriately, and updates its model at the right pace."}],["$","pre",null,{"children":["$","code",null,{"children":"TI: [40–70]  SG: [30–60]  FT: [30–60]\nUE: [40–70]  AR: [40–70]"}]}],["$","h2",null,{"children":"Near Oscillation"}],["$","p",null,{"children":[["$","strong",null,{"children":"Condition:"}]," TI ≥ 65 ",["$","em",null,{"children":"and"}]," SG ≥ 55."]}],["$","p",null,{"children":"The agent integrates a long history (high TI) while amplifying signals strongly (high SG). It revisits the same evidence repeatedly without committing. In production this looks like:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Agent re-reads the same context repeatedly"}],["$","li",null,{"children":"Tool calls issued, then immediately retried with slight variations"}],["$","li",null,{"children":"Agent fails to commit to a conclusion despite sufficient information"}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Fix:"}]," Lower SG (raise temperature) or reduce TI (shorter context window)."]}],["$","h2",null,{"children":"Near Overload"}],["$","p",null,{"children":[["$","strong",null,{"children":"Condition:"}]," TI ≤ 35 ",["$","em",null,{"children":"and"}]," SG ≥ 65."]}],["$","p",null,{"children":"The agent processes only a short window (low TI) while strongly amplifying signals (high SG). It acts on insufficient information. In production:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Agent hallucinates tool parameters or invents facts"}],["$","li",null,{"children":"Confident conclusions reached far too quickly"}],["$","li",null,{"children":"Retry logic triggers on valid outputs"}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Fix:"}]," Lower SG (raise temperature) or raise FT (add explicit confirmation)."]}],["$","h2",null,{"children":"Near Freeze"}],["$","p",null,{"children":[["$","strong",null,{"children":"Condition:"}]," UE ≤ 35 ",["$","em",null,{"children":"and"}]," FT ≥ 65."]}],["$","p",null,{"children":"The agent resists updating its model (low UE) and applies a high filter before acting (high FT). It hedges endlessly. In production:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Agent produces verbose hedging without committing"}],["$","li",null,{"children":"Requests clarification on well-specified tasks"}],["$","li",null,{"children":"Tool calls never issued despite clear instructions"}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Fix:"}]," Lower FT or raise UE. Adjust commitment style from cautious to balanced."]}],["$","h2",null,{"children":"The oscillation threshold"}],["$","p",null,{"children":["In addition to the four regimes, the tuner checks the ",["$","strong",null,{"children":"oscillation threshold"}],":"]}],["$","pre",null,{"children":["$","code",null,{"children":"SG × TI > 7000 → oscillation risk warning"}]}],["$","p",null,{"children":"This is a soft boundary — the agent may still be classified \"stable\" while exceeding it, but the risk is elevated and a warning is surfaced. This threshold comes from Paper 9 §oscillatory threshold in the RPCS-1 framework."}]]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","docs","children","regimes","children"],"error":"$undefined","errorStyles":"$u