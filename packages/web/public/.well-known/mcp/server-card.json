{
  "serverInfo": {
    "name": "RPCS1 Agent Tuner",
    "version": "0.2.2"
  },
  "authentication": {
    "required": false,
    "schemes": []
  },
  "tools": [
    {
      "name": "recommend_agent_configuration",
      "description": "Diagnose whether a deployed AI agent is matched to its operating environment. Returns receiver profile values, platform parameters, confidence, reasoning, and warnings.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "task": {
            "type": "object",
            "properties": {
              "task_summary": {
                "type": "string",
                "description": "Description of what the AI agent does"
              },
              "domain": {
                "type": "string",
                "description": "Optional domain"
              },
              "expected_duration_per_call": {
                "type": "string",
                "enum": [
                  "short",
                  "medium",
                  "long"
                ]
              }
            }
          },
          "environment": {
            "type": "object",
            "properties": {
              "entropy": {
                "type": "string",
                "enum": [
                  "stable",
                  "moderate",
                  "dynamic",
                  "chaotic"
                ]
              },
              "predictability": {
                "type": "string",
                "enum": [
                  "highly_predictable",
                  "somewhat_predictable",
                  "unpredictable"
                ]
              },
              "stakes": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "catastrophic"
                ]
              },
              "context_relevance": {
                "type": "string",
                "enum": [
                  "short",
                  "medium",
                  "long"
                ]
              },
              "commitment_style": {
                "type": "string",
                "enum": [
                  "decisive",
                  "balanced",
                  "cautious"
                ]
              }
            }
          },
          "target_platform": {
            "type": "string",
            "enum": [
              "anthropic",
              "openai",
              "open_source",
              "generic"
            ]
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "openWorldHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "interpret",
      "description": "Detect ambiguity in user messages. Returns AR level (AR0-AR5), confidence, candidate interpretations, clarifying questions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The message to interpret"
          },
          "risk": {
            "type": "string",
            "enum": [
              "casual",
              "advice",
              "high-stakes",
              "safety-critical"
            ]
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "openWorldHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "normalize",
      "description": "Clean up fragmented human input with ellipses and run-on thoughts into coherent prose.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Fragmented text to normalize"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "openWorldHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "rewrite",
      "description": "Get rewrite instructions for adapting text to a target audience style: technical, plain, gentle, concise, detailed, or direct.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to rewrite"
          },
          "style": {
            "type": "string",
            "enum": [
              "technical",
              "plain",
              "socially_gentle",
              "concise",
              "detailed",
              "direct"
            ]
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "openWorldHint": false,
        "idempotentHint": true
      }
    }
  ],
  "resources": [],
  "prompts": []
}